<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050507"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/visualStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1A1A1E"
            android:ellipsize="end"
            android:maxLines="2"
            android:padding="10dp"
            android:text="Idle"
            android:textColor="#E9EAED"
            android:textSize="14sp" />

        <Button
            android:id="@+id/closeVisualButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:backgroundTint="#2E2F35"
            android:text="&#x5173;&#x95ED;"
            android:textColor="#F4F5F7" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/visualLongReplyChoiceContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/visualLongReplySummaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#2E5CB8"
            android:text="&#x7B80;&#x62A5;"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/visualLongReplyOriginalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#2E2F35"
            android:text="&#x539F;&#x6587;"
            android:textColor="#F4F5F7" />
    </LinearLayout>

    <com.audiobridge.client.ui.EyeAvatarView
        android:id="@+id/eyeAvatarView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1.4" />

    <LinearLayout
        android:id="@+id/subtitleRowContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/localSubtitleCardContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#111214"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="&#x672C;&#x5730;&#x63A5;&#x7EBF;&#x5458;"
                    android:textColor="#79E0CF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/localSubtitleToggleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="&#x5C55;&#x5F00;"
                    android:textAllCaps="false"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/localSubtitleText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="(&#x6682;&#x65E0;)"
                android:textColor="#D4F4EE"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openclawSubtitleCardContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="#111214"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="&#x9F99;&#x867E;&#x5927;&#x8111;"
                    android:textColor="#84B8FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/openclawSubtitleToggleButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="&#x5C55;&#x5F00;"
                    android:textAllCaps="false"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/openclawSubtitleText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="6dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="(&#x6682;&#x65E0;)"
                android:textColor="#DCE9FF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/visualInputText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1A1A1E"
            android:hint="&#x8F93;&#x5165;&#x6587;&#x672C;..."
            android:inputType="textMultiLine"
            android:maxLines="2"
            android:minHeight="48dp"
            android:padding="10dp"
            android:textColor="#F2F3F5"
            android:textColorHint="#8F949C" />

        <Button
            android:id="@+id/visualSendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#2A6BF2"
            android:text="&#x53D1;&#x9001;"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/visualSttButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#214A77"
            android:text="&#x8BED;&#x97F3;"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
